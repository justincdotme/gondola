# Required
SENSOR_GATEWAY_API_KEY=your-secret-key-here

# Optional (defaults shown)
SENSOR_DB_PATH=./readings.db
SENSOR_WRITE_INTERVAL=60
SENSOR_RETENTION_DAYS=90
SENSOR_HOST=0.0.0.0
SENSOR_PORT=8075
BLUETOOTH_ADAPTER=

# TLS (optional, set both to enable HTTPS on port 8443)
# Run init.sh to generate a self-signed cert, or set paths to your own.
# Leave empty for HTTP only (port 8075).
SENSOR_TLS_CERT=
SENSOR_TLS_KEY=

# Error tracking (optional, GlitchTip/Sentry DSN)
SENTRY_DSN=
